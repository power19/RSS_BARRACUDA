<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="robots" content="noindex, nofollow, noarchive, nosnippet">
<meta name="copyright" content="© 2026 B-MAX Media N.V. All Rights Reserved.">
<title>B-MAX Media N.V. — Secure Document Access</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Barlow:wght@300;400;600;700&display=swap');

  :root {
    --navy: #0a2342;
    --navy-mid: #1a3a5c;
    --accent: #4fc3f7;
    --warn: #e65100;
    --green: #00e676;
    --red: #ff1744;
    --bg: #07111f;
    --surface: #0d1e30;
    --border: rgba(79,195,247,0.2);
    --text: #e0f0ff;
    --mono: 'Share Tech Mono', monospace;
    --sans: 'Barlow', sans-serif;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--sans);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  /* Grid background */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image:
      linear-gradient(rgba(79,195,247,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(79,195,247,0.04) 1px, transparent 1px);
    background-size: 40px 40px;
    pointer-events: none;
    z-index: 0;
  }

  /* Radial glow */
  body::after {
    content: '';
    position: fixed;
    inset: 0;
    background: radial-gradient(ellipse 60% 50% at 50% 50%, rgba(10,35,66,0.6) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }

  #login-wrap {
    position: relative;
    z-index: 10;
    width: 100%;
    max-width: 440px;
    padding: 20px;
    animation: fadeUp 0.6s ease both;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .login-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 36px 32px 32px;
    box-shadow: 0 8px 40px rgba(0,0,0,0.6), 0 0 0 1px rgba(79,195,247,0.08);
    position: relative;
    overflow: hidden;
  }

  .login-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--navy), var(--accent), var(--navy));
    background-size: 200%;
    animation: shimmer 3s linear infinite;
  }

  @keyframes shimmer {
    0%   { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 28px;
  }

  .brand-icon {
    width: 44px;
    height: 44px;
    background: linear-gradient(135deg, var(--navy), var(--navy-mid));
    border: 1px solid var(--border);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    flex-shrink: 0;
  }

  .brand-text h1 {
    font-size: 14px;
    font-weight: 700;
    color: var(--accent);
    letter-spacing: 1.5px;
    text-transform: uppercase;
  }

  .brand-text p {
    font-size: 11px;
    color: #5a8aaa;
    margin-top: 2px;
    font-family: var(--mono);
  }

  .doc-badge {
    background: rgba(79,195,247,0.08);
    border: 1px solid rgba(79,195,247,0.15);
    border-radius: 8px;
    padding: 12px 14px;
    margin-bottom: 24px;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .doc-badge-icon { font-size: 20px; }

  .doc-badge-info h2 {
    font-size: 13px;
    font-weight: 600;
    color: var(--text);
  }

  .doc-badge-info p {
    font-size: 11px;
    color: #5a8aaa;
    font-family: var(--mono);
    margin-top: 2px;
  }

  .field-group {
    margin-bottom: 16px;
  }

  .field-group label {
    display: block;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: #5a8aaa;
    margin-bottom: 6px;
    font-family: var(--mono);
  }

  .field-group input {
    width: 100%;
    background: rgba(10,35,66,0.6);
    border: 1px solid rgba(79,195,247,0.2);
    border-radius: 7px;
    padding: 11px 14px;
    font-size: 14px;
    color: var(--text);
    font-family: var(--sans);
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .field-group input:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(79,195,247,0.12);
  }

  .field-group input::placeholder { color: #2a4a6a; }

  .login-btn {
    width: 100%;
    padding: 13px;
    background: linear-gradient(135deg, var(--navy), var(--navy-mid));
    border: 1px solid rgba(79,195,247,0.3);
    border-radius: 7px;
    color: var(--accent);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    cursor: pointer;
    font-family: var(--sans);
    transition: all 0.2s;
    margin-top: 8px;
    position: relative;
    overflow: hidden;
  }

  .login-btn:hover {
    background: linear-gradient(135deg, #0f2e55, #1e4470);
    border-color: var(--accent);
    box-shadow: 0 0 20px rgba(79,195,247,0.15);
    transform: translateY(-1px);
  }

  .login-btn:active { transform: translateY(0); }

  .login-btn.loading {
    pointer-events: none;
    opacity: 0.7;
  }

  #error-msg {
    display: none;
    background: rgba(255,23,68,0.1);
    border: 1px solid rgba(255,23,68,0.3);
    border-radius: 7px;
    padding: 10px 14px;
    font-size: 12px;
    color: #ff6b6b;
    margin-top: 14px;
    font-family: var(--mono);
    animation: shake 0.3s ease;
  }

  @keyframes shake {
    0%,100% { transform: translateX(0); }
    25% { transform: translateX(-6px); }
    75% { transform: translateX(6px); }
  }

  .footer-note {
    margin-top: 20px;
    text-align: center;
    font-size: 10px;
    color: #2a4060;
    font-family: var(--mono);
    line-height: 1.6;
  }

  /* ─── DOCUMENT FRAME ────────────────────────────────────── */
  #doc-frame {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 100;
    flex-direction: column;
    background: #f5f7fa;
  }

  #doc-toolbar {
    background: var(--navy);
    color: white;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 16px;
    height: 44px;
    flex-shrink: 0;
    font-family: var(--sans);
    font-size: 12px;
    gap: 12px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.3);
    z-index: 200;
    position: relative;
  }

  #doc-toolbar .tb-left {
    display: flex;
    align-items: center;
    gap: 10px;
    font-weight: 600;
    letter-spacing: 0.5px;
    color: var(--accent);
    font-size: 12px;
  }

  #doc-toolbar .tb-right {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .tb-badge {
    background: rgba(79,195,247,0.15);
    border: 1px solid rgba(79,195,247,0.25);
    border-radius: 4px;
    padding: 2px 8px;
    font-size: 10px;
    color: #90caf9;
    font-family: var(--mono);
  }

  .tb-btn {
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 5px;
    padding: 4px 12px;
    color: white;
    font-size: 11px;
    cursor: pointer;
    font-family: var(--sans);
    font-weight: 600;
    transition: background 0.15s;
    display: flex;
    align-items: center;
    gap: 5px;
  }

  .tb-btn:hover { background: rgba(255,255,255,0.15); }
  .tb-btn.print-btn { color: var(--accent); border-color: rgba(79,195,247,0.3); }
  .tb-btn.logout-btn { color: #ff8a80; border-color: rgba(255,100,80,0.3); }

  #doc-content {
    flex: 1;
    overflow: auto;
    position: relative;
  }

  /* Watermark overlay on doc content */
  #doc-content::before {
    content: '';
    position: fixed;
    inset: 44px 0 0 0;
    pointer-events: none;
    z-index: 150;
    background-image: repeating-linear-gradient(
      -45deg,
      transparent,
      transparent 120px,
      rgba(10, 35, 66, 0.035) 120px,
      rgba(10, 35, 66, 0.035) 122px
    );
  }

  #doc-inner {
    position: relative;
  }

  /* Watermark text rendered via canvas-like approach using CSS */
  .wm-layer {
    position: fixed;
    inset: 44px 0 0 0;
    pointer-events: none;
    z-index: 151;
    overflow: hidden;
  }

  .wm-text {
    position: absolute;
    white-space: nowrap;
    font-family: var(--mono);
    font-size: 13px;
    font-weight: 400;
    color: rgba(10,35,66,0.09);
    transform-origin: center;
    transform: rotate(-30deg);
    letter-spacing: 2px;
    pointer-events: none;
    user-select: none;
  }

  /* ─── PRINT STYLES ──────────────────────────────────────── */
  @media print {
    #doc-toolbar { display: none !important; }
    .wm-layer { display: none !important; }
    #doc-frame {
      position: static;
      display: block !important;
    }
    #doc-content { overflow: visible; }
    /* Print watermark via page header */
    @page {
      margin: 1.5cm;
    }
    body::after {
      content: '© B-MAX Media N.V. — CONFIDENTIAL';
      position: fixed;
      bottom: 10px;
      right: 10px;
      font-size: 8px;
      color: rgba(0,0,0,0.25);
      font-family: monospace;
    }
  }

  /* ─── RIGHT-CLICK SHIELD ─────────────────────────────────── */
  #rcm-shield {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: transparent;
  }

  /* ─── SESSION TIMER ─────────────────────────────────────── */
  #session-timer {
    font-family: var(--mono);
    font-size: 11px;
    color: #5a8aaa;
  }
  #session-timer.warn { color: #ff8a80; animation: blink 1s step-end infinite; }
  @keyframes blink { 50% { opacity: 0.4; } }
</style>
</head>
<body>

<!-- LOGIN SCREEN -->
<div id="login-wrap">
  <div class="login-card">
    <div class="brand">
      <div class="brand-icon">⚓</div>
      <div class="brand-text">
        <h1>B-MAX Media N.V.</h1>
        <p>Secure Document Portal · Paramaribo, SR</p>
      </div>
    </div>

    <div class="doc-badge">
      <div class="doc-badge-icon">📋</div>
      <div class="doc-badge-info">
        <h2>RSS Barracuda — GMDSS Inspection Report</h2>
        <p>CLASSIFIED · Authorized Recipients Only</p>
      </div>
    </div>

    <div class="field-group">
      <label>Access Code</label>
      <input type="password" id="pwd-input" placeholder="Enter access code" autocomplete="off" spellcheck="false">
    </div>

    <button class="login-btn" id="login-btn" onclick="attemptLogin()">
      🔐 &nbsp;Unlock Document
    </button>

    <div id="error-msg">⚠ Invalid access code. Contact B-MAX Media N.V.</div>

    <div class="footer-note">
      © 2026 B-MAX Media N.V. · All Rights Reserved<br>
      Unauthorized access or distribution is prohibited.<br>
      This session is logged.
    </div>
  </div>
</div>

<!-- DOCUMENT FRAME (hidden until login) -->
<div id="doc-frame">
  <div id="doc-toolbar">
    <div class="tb-left">
      <span>⚓</span>
      <span>RSS BARRACUDA — GMDSS Inspection Report</span>
      <span class="tb-badge">CONFIDENTIAL</span>
      <span class="tb-badge">© B-MAX Media N.V. 2026</span>
    </div>
    <div class="tb-right">
      <span id="session-timer">Session: 30:00</span>
      <button class="tb-btn print-btn" onclick="printDoc()">🖨 Print</button>
      <button class="tb-btn logout-btn" onclick="lockDoc()">🔒 Lock</button>
    </div>
  </div>

  <div id="doc-content">
    <div class="wm-layer" id="wm-layer"></div>
    <div id="doc-inner"></div>
  </div>
</div>

<script>
// ═══════════════════════════════════════════════════
//  SECURITY CONFIGURATION
// ═══════════════════════════════════════════════════

// Session duration in minutes
const SESSION_MINUTES = 30;

// Watermark text
const WM_TEXT = '© B-MAX MEDIA N.V. · CONFIDENTIAL · AUTHORIZED USE ONLY';

// Access log (client-side record)
const ACCESS_LOG = [];

// ═══════════════════════════════════════════════════
//  ENCODED DOCUMENT CONTENT
// ═══════════════════════════════════════════════════
const DOC_B64 = '';

// ═══════════════════════════════════════════════════
//  SHA-256 HELPER (Web Crypto API)
// ═══════════════════════════════════════════════════
async function sha256(message) {
  const msgBuffer = new TextEncoder().encode(message);
  const hashBuffer = await crypto.subtle.digest('SHA-256', msgBuffer);
  const hashArray = Array.from(new Uint8Array(hashBuffer));
  return hashArray.map(b => b.toString(16).padStart(2, '0')).join('');
}

// ═══════════════════════════════════════════════════
//  LOGIN LOGIC
// ═══════════════════════════════════════════════════
let attempts = 0;
const MAX_ATTEMPTS = 5;
let lockoutUntil = 0;
let sessionTimeout = null;
let sessionEnd = 0;
let timerInterval = null;

async function attemptLogin() {
  const now = Date.now();
  if (now < lockoutUntil) {
    const secs = Math.ceil((lockoutUntil - now) / 1000);
    showError(`Too many attempts. Wait ${secs}s.`);
    return;
  }

  const pwd = document.getElementById('pwd-input').value;
  if (!pwd) return;

  const btn = document.getElementById('login-btn');
  btn.classList.add('loading');
  btn.textContent = 'Verifying...';

  // Small delay to prevent brute force timing
  await new Promise(r => setTimeout(r, 400 + Math.random() * 300));

  const hash = await sha256(pwd);

  // NOTE: Replace PASS_HASH above with the actual hash.
  // For deployment, generate: sha256("YourPassword") using browser console or:
  // https://emn178.github.io/online-tools/sha256.html

  const correct = await checkPassword(pwd);

  if (correct) {
    attempts = 0;
    logAccess('LOGIN_SUCCESS');
    loadDocument();
  } else {
    attempts++;
    logAccess('LOGIN_FAIL');

    if (attempts >= MAX_ATTEMPTS) {
      lockoutUntil = Date.now() + 60000; // 60s lockout
      showError(`Account locked for 60 seconds (${MAX_ATTEMPTS} failed attempts).`);
      attempts = 0;
    } else {
      showError(`Invalid code. ${MAX_ATTEMPTS - attempts} attempt(s) remaining.`);
    }

    btn.classList.remove('loading');
    btn.innerHTML = '🔐 &nbsp;Unlock Document';
    document.getElementById('pwd-input').value = '';
    document.getElementById('pwd-input').focus();
  }
}

// ─── PASSWORD CHECK (SHA-256 — plaintext never stored) ────────
// The password is stored only as a SHA-256 hash below.
// The raw password does NOT exist anywhere in this file.
// To set a new password:
//   1. Run: sha256("YourNewPassword") in browser console, OR
//   2. Visit https://emn178.github.io/online-tools/sha256.html
//   3. Paste the resulting hex hash below, replacing PASS_HASH
const PASS_HASH = '5273fc381862176dcbd8f6741b14b634e8190d6f840f4db381be9cfd2a3ebd30';

async function checkPassword(pwd) {
  const hashed = await sha256(pwd);
  // Constant-time comparison to prevent timing attacks
  if (hashed.length !== PASS_HASH.length) return false;
  let diff = 0;
  for (let i = 0; i < hashed.length; i++) {
    diff |= hashed.charCodeAt(i) ^ PASS_HASH.charCodeAt(i);
  }
  return diff === 0;
}

function showError(msg) {
  const el = document.getElementById('error-msg');
  el.textContent = '⚠ ' + msg;
  el.style.display = 'block';
  el.style.animation = 'none';
  void el.offsetWidth;
  el.style.animation = 'shake 0.3s ease';
}

// ═══════════════════════════════════════════════════
//  DOCUMENT LOADING
// ═══════════════════════════════════════════════════
function loadDocument() {
  // Decode base64 to raw HTML string
  const raw = atob(DOC_B64);
  const decoded = decodeURIComponent(escape(raw));

  // Use a Blob URL so the full HTML (including scripts/styles) renders correctly
  const blob = new Blob([decoded], { type: 'text/html' });
  const blobUrl = URL.createObjectURL(blob);

  // Replace doc-inner with an iframe pointing to the blob
  const inner = document.getElementById('doc-inner');
  inner.innerHTML = '';
  const iframe = document.createElement('iframe');
  iframe.id = 'doc-iframe';
  iframe.src = blobUrl;
  iframe.style.cssText = 'width:100%;height:calc(100vh - 44px);border:none;display:block;';
  iframe.onload = () => URL.revokeObjectURL(blobUrl); // free memory
  inner.appendChild(iframe);

  // Show document frame
  document.body.style.overflow = 'hidden';
  document.getElementById('login-wrap').style.display = 'none';
  const frame = document.getElementById('doc-frame');
  frame.style.display = 'flex';

  // Build watermark
  buildWatermark();

  // Start session timer
  startSession();

  // Security hooks
  installSecurityHooks();
}

// ═══════════════════════════════════════════════════
//  WATERMARK
// ═══════════════════════════════════════════════════
function buildWatermark() {
  const layer = document.getElementById('wm-layer');
  layer.innerHTML = '';
  const W = window.innerWidth;
  const H = window.innerHeight;
  const rows = Math.ceil(H / 90) + 5;
  const cols = Math.ceil(W / 340) + 3;

  for (let r = 0; r < rows; r++) {
    for (let c = 0; c < cols; c++) {
      const el = document.createElement('div');
      el.className = 'wm-text';
      el.textContent = WM_TEXT;
      el.style.top = `${r * 90 - 20}px`;
      el.style.left = `${c * 340 - 60}px`;
      layer.appendChild(el);
    }
  }
}

window.addEventListener('resize', () => {
  if (document.getElementById('doc-frame').style.display !== 'none') buildWatermark();
});

// ═══════════════════════════════════════════════════
//  SESSION TIMER
// ═══════════════════════════════════════════════════
function startSession() {
  sessionEnd = Date.now() + SESSION_MINUTES * 60 * 1000;
  updateTimer();
  timerInterval = setInterval(updateTimer, 1000);
}

function updateTimer() {
  const rem = Math.max(0, sessionEnd - Date.now());
  const m = Math.floor(rem / 60000);
  const s = Math.floor((rem % 60000) / 1000);
  const el = document.getElementById('session-timer');
  el.textContent = `Session: ${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}`;

  if (rem <= 120000) el.classList.add('warn');
  else el.classList.remove('warn');

  if (rem === 0) {
    clearInterval(timerInterval);
    lockDoc(true);
  }
}

// ═══════════════════════════════════════════════════
//  LOCK / LOGOUT
// ═══════════════════════════════════════════════════
function lockDoc(expired = false) {
  clearInterval(timerInterval);
  logAccess(expired ? 'SESSION_EXPIRED' : 'LOGOUT');
  document.getElementById('doc-frame').style.display = 'none';
  const iframe = document.getElementById('doc-iframe');
  if (iframe && iframe.src) iframe.src = 'about:blank';
  document.getElementById('doc-inner').innerHTML = '';
  document.getElementById('login-wrap').style.display = 'flex';
  document.body.style.overflow = 'hidden';

  const errEl = document.getElementById('error-msg');
  if (expired) {
    errEl.textContent = '⚠ Session expired. Please re-authenticate.';
    errEl.style.display = 'block';
  } else {
    errEl.style.display = 'none';
  }

  document.getElementById('pwd-input').value = '';
  setTimeout(() => document.getElementById('pwd-input').focus(), 100);
}

// ═══════════════════════════════════════════════════
//  PRINT
// ═══════════════════════════════════════════════════
function printDoc() {
  logAccess('PRINT');
  window.print();
}

// ═══════════════════════════════════════════════════
//  SECURITY HOOKS
// ═══════════════════════════════════════════════════
function installSecurityHooks() {
  // Place a transparent full-cover div over the iframe to block right-click & selection
  const shield = document.createElement('div');
  shield.id = 'iframe-shield';
  shield.style.cssText = [
    'position:fixed',
    'top:44px',
    'left:0',
    'right:0',
    'bottom:0',
    'z-index:160',
    'background:transparent',
    'pointer-events:none',   // allows scrolling through
  ].join(';');
  // Only intercept context menu
  shield.addEventListener('contextmenu', e => { e.preventDefault(); return false; });
  document.body.appendChild(shield);

  // Disable drag on doc-content
  document.getElementById('doc-content').addEventListener('dragstart', e => e.preventDefault());

  // Warn on tab visibility change (potential screen capture)
  document.addEventListener('visibilitychange', () => {
    if (document.visibilityState === 'hidden') {
      logAccess('TAB_HIDDEN');
    }
  });

  // Detect Dev Tools (basic heuristic)
  let devToolsWarned = false;
  const detectDevTools = () => {
    const threshold = 200;
    if (window.outerHeight - window.innerHeight > threshold || window.outerWidth - window.innerWidth > threshold) {
      if (!devToolsWarned) {
        devToolsWarned = true;
        logAccess('DEVTOOLS_DETECTED');
      }
    }
  };
  setInterval(detectDevTools, 3000);
}

// ═══════════════════════════════════════════════════
//  ACCESS LOG (client-side)
// ═══════════════════════════════════════════════════
function logAccess(event) {
  const entry = {
    event,
    ts: new Date().toISOString(),
    ua: navigator.userAgent.substring(0, 80),
  };
  ACCESS_LOG.push(entry);
  // In a real deployment, send to server via fetch('/api/log', {...})
  console.log('[B-MAX SECURE]', entry);
}

// ═══════════════════════════════════════════════════
//  KEYBOARD SHORTCUT: Enter to submit
// ═══════════════════════════════════════════════════
document.getElementById('pwd-input').addEventListener('keydown', e => {
  if (e.key === 'Enter') attemptLogin();
});

// ═══════════════════════════════════════════════════
//  DISABLE SAVE / VIEW SOURCE shortcuts on doc
// ═══════════════════════════════════════════════════
document.addEventListener('keydown', e => {
  if (document.getElementById('doc-frame').style.display === 'none') return;
  // Block Ctrl+S, Ctrl+U, Ctrl+A, F12
  if ((e.ctrlKey || e.metaKey) && ['s','u','a'].includes(e.key.toLowerCase())) {
    e.preventDefault();
  }
  if (e.key === 'F12') e.preventDefault();
});

// Prevent right-click globally on login screen too
document.getElementById('login-wrap').addEventListener('contextmenu', e => e.preventDefault());

